# Ignore Microsoft Word temporary lock files
~$*.docx
~$*.doc
~$*.xlsx
~$*.pptx

# Ignore OS temporary files
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

# Ignore Node.js / local dev dependencies (just in case)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Ignore local environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Ignore IDE/Editor configurations
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.user
.history/

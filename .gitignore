# PMN Framework - Public Repository .gitignore
# This is the minimal, safe version committed to GitHub.
#
# For the full detailed ignore rules (including private workspace layout),
# see: private/configs/.gitignore.public-full

# Microsoft Word temporary lock files
~$*.docx
~$*.doc
~$*.xlsx
~$*.pptx

# OS temporary files
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment & secrets
.env
.env.local
.env.*.local

# IDE / Editor
.vscode/
.idea/
*.suo
*.user
.history/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/

# Local build artifacts & backups
*.bak
index.html.bak
legacy/index.offline.html
legacy/app.js
LENGKAPI_DIAGNOSIS_UNTUK_AI.md

# PMN Workspace specific
pmn_system_log.txt
config.enc
private/
backup/
*.enc

# Database schema — keep local only, not for public repo
supabase/

# Internal product/planning docs
PRD.md

# Ignore versioned release assets to prevent Git history bloat
dist/PMN_Framework_v*.pdf
dist/PMN_Framework_v*.md
public_static/PMN_Framework_v*.pdf
public_static/PMN_Framework_v*.md

# Internal-only backup snapshots (stale, not for public repo)
src/txt/
index.ui.2.html

# Ignore Microsoft Word temporary lock files
~$*.docx
~$*.doc
~$*.xlsx
~$*.pptx

# Ignore OS temporary files
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

# Ignore Node.js / local dev dependencies (just in case)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Ignore local environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Ignore IDE/Editor configurations
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.user
.history/

# Ignore Python Caches and Compiled Folders
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/

# Ignore Compiled Backups and Local Artifacts
*.bak
index.html.bak
backups/
LENGKAPI_DIAGNOSIS_UNTUK_AI.md

# Ignore local secure document sandbox directories and legacy release binaries
docs/raw_inputs/
docs/clean_outputs/
docs/clean_output/
docs/Anonymous
docs/*.docx
docs/*.pdf

